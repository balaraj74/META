# ─── Model ───────────────────────────────────────────────
HF_TOKEN=your_huggingface_token
BASE_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_REPO_ID=your_username/triage-hospital-agent
USE_MOCK_LLM=false
LLM_MODE=hf
CLINICAL_MODEL=Intelligent-Internet/II-Medical-8B
OPERATIONS_MODEL=Qwen/Qwen3-4B-Instruct
CLINICAL_MODEL_PATH=./models/ii-medical-8b
OPERATIONS_MODEL_PATH=./models/qwen3-4b
CLINICAL_GRPO_ADAPTER=./models/grpo_clinical_adapter
OPERATIONS_GRPO_ADAPTER=./models/grpo_operations_adapter
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CLINICAL_MODEL=qwen3:8b
OLLAMA_OPERATIONS_MODEL=qwen3:4b

# ─── Database ────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./triage.db
# For production: postgresql+asyncpg://triage:triage@localhost:5432/triage

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
USE_REDIS=false

# ─── API ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Simulation ──────────────────────────────────────────
MAX_STEPS_PER_EPISODE=500
SCHEMA_DRIFT_ENABLED=true
EXPERT_MODE=false
MOCK_LLM=true

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO
